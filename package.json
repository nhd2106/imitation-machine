{
  "name": "@duoc95/imitation-machine",
  "version": "0.1.0",
  "description": "Enterprise agentic SDLC plugin and CLI for OpenCode and Claude-style skill workflows",
  "license": "MIT",
  "type": "module",
  "main": ".opencode/plugins/imitation-machine.js",
  "private": true,
  "bin": {
